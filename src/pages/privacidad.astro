---
import Layout from "@/layouts/Layout.astro";
import SectionHeading from "@/components/shared/SectionHeading.astro";
import { privacidad } from "@/constants/privacidad";

const {
  meta,
  hero,
  lastUpdated,
  responsable,
  datosRecabados,
  finalidades,
  noCompartimos,
  transferencias,
  derechos,
  cookies,
  seguridad,
  cambios,
  legislacion,
  contacto,
} = privacidad;
---

<Layout title={meta.title} description={meta.description}>
  <!-- Page Header -->
  <section class="border-b border-line bg-panel">
    <div class="mx-auto max-w-7xl px-5 py-16 md:px-8 md:py-24">
      <SectionHeading
        eyebrow={hero.eyebrow}
        title={hero.title}
        description={hero.description}
      />
      <p class="mt-6 text-xs text-muted">
        Última actualización: <span class="font-medium text-ink"
          >{lastUpdated}</span
        >
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="mx-auto max-w-7xl px-5 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <!-- Responsable -->
      <article class="mb-12">
        <h2 class="font-display text-xl font-medium text-ink md:text-2xl">
          {responsable.heading}
        </h2>
        <div class="rule-gold mt-3 mb-5"></div>
        {
          responsable.body.map((p) => (
            <p class="mb-4 text-base leading-relaxed text-muted">{p}</p>
          ))
        }
      </article>

      <!-- Datos recabados -->
      <article class="mb-12">
        <h2 class="font-display text-xl font-medium text-ink md:text-2xl">
          {datosRecabados.heading}
        </h2>
        <div class="rule-gold mt-3 mb-5"></div>
        <p class="mb-4 text-base leading-relaxed text-muted">
          {datosRecabados.intro}
        </p>
        <ul class="mb-4 space-y-2">
          {
            datosRecabados.items.map((item) => (
              <li class="flex items-start gap-3 text-base text-muted">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-secondary" />
                {item}
              </li>
            ))
          }
        </ul>
        <p
          class="rounded-xl border border-line bg-panel px-5 py-4 text-sm italic leading-relaxed text-muted"
        >
          {datosRecabados.note}
        </p>
      </article>

      <!-- Finalidades -->
      <article class="mb-12">
        <h2 class="font-display text-xl font-medium text-ink md:text-2xl">
          {finalidades.heading}
        </h2>
        <div class="rule-gold mt-3 mb-5"></div>
        <p class="mb-6 text-base leading-relaxed text-muted">
          {finalidades.intro}
        </p>

        <div class="mb-6 rounded-xl border border-line bg-panel p-6">
          <h3
            class="mb-4 text-sm font-semibold uppercase tracking-[0.15em] text-secondary"
          >
            {finalidades.primarias.subheading}
          </h3>
          <ul class="space-y-3">
            {
              finalidades.primarias.items.map((item) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed text-muted">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-secondary" />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>

        <div class="rounded-xl border border-line bg-panel p-6">
          <h3
            class="mb-4 text-sm font-semibold uppercase tracking-[0.15em] text-secondary"
          >
            {finalidades.secundarias.subheading}
          </h3>
          <ul class="mb-4 space-y-3">
            {
              finalidades.secundarias.items.map((item) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed text-muted">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-secondary/50" />
                  {item}
                </li>
              ))
            }
          </ul>
          <p class="text-xs italic leading-relaxed text-muted">
            {finalidades.secundarias.opt}
          </p>
        </div>
      </article>

      <!-- NO compartimos ni vendemos — DESTACADO -->
      <article class="mb-12">
        <div
          class="rounded-2xl border-2 border-secondary/40 bg-secondary/5 p-8"
        >
          <!-- Icon + heading -->
          <div class="mb-5 flex items-start gap-4">
            <span
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-secondary/15 text-secondary"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                ></path>
              </svg>
            </span>
            <h2 class="font-display text-xl font-medium text-ink md:text-2xl">
              {noCompartimos.heading}
            </h2>
          </div>
          <div class="space-y-4">
            {
              noCompartimos.body.map((p, i) => (
                <p
                  class:list={[
                    "leading-relaxed",
                    i === 0
                      ? "text-base font-medium text-ink"
                      : "text-base text-muted",
                  ]}
                >
                  {p}
                </p>
              ))
            }
          </div>
        </div>
      </article>

      <!-- Transferencias -->
      <article class="mb-12">
        <h2 class="font-display text-xl font-medium text-ink md:text-2xl">
          {transferencias.heading}
        </h2>
        <div class="rule-gold mt-3 mb-5"></div>
        {
          transferencias.body.map((p) => (
            <p class="mb-4 text-base leading-relaxed text-muted">{p}</p>
          ))
        }
      </article>

      <!-- Derechos ARCO -->
      <article class="mb-12">
        <h2 class="font-display text-xl font-medium text-ink md:text-2xl">
          {derechos.heading}
        </h2>
        <div class="rule-gold mt-3 mb-5"></div>
        <p class="mb-5 text-base leading-relaxed text-muted">
          {derechos.intro}
        </p>
        <ol class="space-y-3">
          {
            derechos.steps.map((step, i) => (
              <li class="flex items-start gap-4 text-base leading-relaxed text-muted">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary/10 text-xs font-semibold text-primary">
                  {i + 1}
                </span>
                {step}
              </li>
            ))
          }
        </ol>
      </article>

      <!-- Cookies -->
      <!-- <article class="mb-12">
        <h2 class="font-display text-xl font-medium text-ink md:text-2xl">
          {cookies.heading}
        </h2>
        <div class="rule-gold mt-3 mb-5"></div>
        {cookies.body.map((p) => (
          <p class="mb-4 text-base leading-relaxed text-muted">{p}</p>
        ))}
      </article> -->

      <!-- Seguridad -->
      <article class="mb-12">
        <h2 class="font-display text-xl font-medium text-ink md:text-2xl">
          {seguridad.heading}
        </h2>
        <div class="rule-gold mt-3 mb-5"></div>
        {
          seguridad.body.map((p) => (
            <p class="mb-4 text-base leading-relaxed text-muted">{p}</p>
          ))
        }
      </article>

      <!-- Cambios -->
      <article class="mb-12">
        <h2 class="font-display text-xl font-medium text-ink md:text-2xl">
          {cambios.heading}
        </h2>
        <div class="rule-gold mt-3 mb-5"></div>
        {
          cambios.body.map((p) => (
            <p class="mb-4 text-base leading-relaxed text-muted">{p}</p>
          ))
        }
      </article>

      <!-- Legislación -->
      <article class="mb-12">
        <h2 class="font-display text-xl font-medium text-ink md:text-2xl">
          {legislacion.heading}
        </h2>
        <div class="rule-gold mt-3 mb-5"></div>
        {
          legislacion.body.map((p) => (
            <p class="mb-4 text-base leading-relaxed text-muted">{p}</p>
          ))
        }
      </article>

      <!-- Contacto final -->
      <div class="rounded-2xl border border-line bg-panel p-8">
        <h2 class="font-display text-xl font-medium text-ink">
          {contacto.heading}
        </h2>
        <div class="rule-gold mt-3 mb-5"></div>
        <p class="mb-6 text-base leading-relaxed text-muted">{contacto.body}</p>
        <ul class="space-y-4 text-sm text-muted">
          <li class="flex items-center gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0 text-secondary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <a
              href={contacto.emailHref}
              class="transition-colors hover:text-secondary"
            >
              {contacto.email}
            </a>
          </li>
          <li class="flex items-center gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0 text-secondary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            <a
              href={contacto.phoneHref}
              class="transition-colors hover:text-secondary"
            >
              {contacto.phone}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="mt-0.5 h-4 w-4 shrink-0 text-secondary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>{contacto.address}</span>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
