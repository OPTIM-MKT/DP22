---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import SectionHeading from "@/components/shared/SectionHeading.astro";
import Card from "@/components/propiedades/Card.astro";
import { propiedadesPage, typeFilters } from "@/constants/propiedades";

const properties = await getCollection("propiedades");
// Available first, then by featured.
const sorted = properties.sort((a, b) => {
  const av = a.data.status === "disponible" ? 1 : 0;
  const bv = b.data.status === "disponible" ? 1 : 0;
  if (av !== bv) return bv - av;
  return Number(b.data.featured ?? 0) - Number(a.data.featured ?? 0);
});
---

<Layout
  title={`Propiedades — ${propiedadesPage.title} | DP22`}
  description={propiedadesPage.description}
>
  <section class="mx-auto max-w-7xl px-5 pt-16 md:px-8 md:pt-24">
    <SectionHeading
      eyebrow={propiedadesPage.eyebrow}
      title={propiedadesPage.title}
      description={propiedadesPage.description}
    />

    <!-- Controls -->
    <div class="mt-10 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div class="relative w-full max-w-md">
        <svg
          class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-muted"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <path stroke-linecap="round" d="m20 20-3-3"></path>
        </svg>
        <input
          id="prop-search"
          type="search"
          placeholder={propiedadesPage.searchPlaceholder}
          class="w-full rounded-full border border-line bg-panel py-3 pl-11 pr-4 text-sm text-ink placeholder:text-muted focus:border-secondary focus:outline-none"
        />
      </div>

      <div class="flex flex-wrap gap-2" id="prop-filters">
        {
          typeFilters.map((f) => (
            <button
              type="button"
              data-filter={f.value}
              class:list={[
                "rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-wider transition-colors",
                f.value === "todos"
                  ? "border-primary bg-primary text-white"
                  : "border-line bg-panel text-muted hover:border-secondary hover:text-ink",
              ]}
            >
              {f.label}
            </button>
          ))
        }
      </div>
    </div>

    <!-- Grid -->
    <div id="prop-grid" class="mt-12 grid gap-6 pb-8 md:grid-cols-2 lg:grid-cols-3">
      {
        sorted.map((entry) => (
          <div
            class="prop-item"
            data-type={entry.data.type}
            data-name={`${entry.data.name} ${entry.data.location ?? ""}`.toLowerCase()}
          >
            <Card entry={entry} morph />
          </div>
        ))
      }
    </div>

    <p
      id="prop-empty"
      class="hidden py-16 text-center text-sm text-muted"
    >
      {propiedadesPage.emptyState}
    </p>
  </section>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const search = document.getElementById("prop-search") as HTMLInputElement | null;
    const filters = document.getElementById("prop-filters");
    const items = Array.from(
      document.querySelectorAll<HTMLElement>(".prop-item"),
    );
    const empty = document.getElementById("prop-empty");
    if (!search || !filters || !items.length) return;

    let activeType = "todos";

    const apply = () => {
      const q = search.value.trim().toLowerCase();
      let visible = 0;
      items.forEach((item) => {
        const matchType =
          activeType === "todos" || item.dataset.type === activeType;
        const matchQuery = !q || (item.dataset.name ?? "").includes(q);
        const show = matchType && matchQuery;
        item.classList.toggle("hidden", !show);
        if (show) visible++;
      });
      empty?.classList.toggle("hidden", visible !== 0);
    };

    search.addEventListener("input", apply);

    filters.querySelectorAll<HTMLButtonElement>("[data-filter]").forEach((btn) => {
      btn.addEventListener("click", () => {
        activeType = btn.dataset.filter ?? "todos";
        filters.querySelectorAll<HTMLButtonElement>("[data-filter]").forEach((b) => {
          const on = b === btn;
          b.classList.toggle("bg-primary", on);
          b.classList.toggle("text-white", on);
          b.classList.toggle("border-primary", on);
          b.classList.toggle("bg-panel", !on);
          b.classList.toggle("text-muted", !on);
          b.classList.toggle("border-line", !on);
        });
        apply();
      });
    });
  });
</script>
