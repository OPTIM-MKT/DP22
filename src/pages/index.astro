---
import Layout from "@/layouts/Layout.astro";
import HeroSlider from "@/components/home/HeroSlider";
import Intro from "@/components/home/Intro.astro";
import Values from "@/components/home/Values.astro";
import PropertiesTeaser from "@/components/home/PropertiesTeaser.astro";
import CtaBanner from "@/components/shared/CtaBanner.astro";
import { heroSlides, homeCta } from "@/constants/home";
import NuestroDesarrollos from "@/components/home/NuestroDesarrollos.astro";
import TestimonialVideo from "@/components/home/TestimonialVideo.astro";
---

<Layout>
  <HeroSlider
    client:load
    slides={heroSlides}
    primaryLabel="Ver propiedades"
    primaryHref="/propiedades"
    secondaryLabel="Conócenos"
    secondaryHref="/acerca"
  />
  <Intro />
  <Values />
  <PropertiesTeaser />
  <NuestroDesarrollos />
  <TestimonialVideo />
  <CtaBanner
    bgSrc={homeCta.bgSrc}
    eyebrow={homeCta.eyebrow}
    title={homeCta.title}
    description={homeCta.description}
    primaryLabel={homeCta.primaryLabel}
    primaryHref={homeCta.primaryHref}
    secondaryLabel={homeCta.secondaryLabel}
    secondaryHref={homeCta.secondaryHref}
  />
</Layout>
