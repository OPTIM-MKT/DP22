---
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import ScrollReveal from "@/components/shared/ScrollReveal";
import SectionHeading from "@/components/shared/SectionHeading.astro";
import CtaBanner from "@/components/shared/CtaBanner.astro";
import { Images } from "@/constants/images";
import {
  acercaHero,
  story,
  mission,
  vision,
  valuesAbout,
  aboutCta,
} from "@/constants/acerca";
---

<Layout title="Nosotros | DP22" description={acercaHero.description}>
  <!-- Hero -->
  <section class="relative h-[55vh] min-h-[420px] overflow-hidden">
    <img
      src={acercaHero.image}
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div
      class="absolute inset-0 bg-linear-to-t from-[#0a111f]/90 via-[#0a111f]/50 to-[#0a111f]/30"
    >
    </div>
    <div
      class="relative mx-auto flex h-full max-w-7xl items-end px-5 pb-14 md:px-8"
    >
      <div class="max-w-2xl">
        <span
          class="text-xs font-medium uppercase tracking-[0.3em] text-secondary"
        >
          {acercaHero.eyebrow}
        </span>
        <h1
          class="mt-3 font-neue text-4xl font-medium text-white md:text-6xl"
        >
          {acercaHero.title}
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-white/80">
          {acercaHero.description}
        </p>
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="mx-auto max-w-7xl px-5 py-20 md:px-8 md:py-28">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">
      <ScrollReveal client:visible direction="left">
        <Image
          src={Images[3].image}
          alt="DP22"
          width={720}
          height={860}
          class="aspect-5/6 w-full rounded-2xl object-cover"
        />
      </ScrollReveal>
      <ScrollReveal client:visible direction="right">
        <SectionHeading eyebrow={story.eyebrow} title={story.title} />
        <div class="mt-6 space-y-4">
          {
            story.paragraphs.map((p) => (
              <p class="text-base leading-relaxed text-muted">{p}</p>
            ))
          }
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Mission / Vision -->
  <section class="border-y border-line bg-panel">
    <div
      class="mx-auto grid max-w-7xl gap-6 px-5 py-20 md:grid-cols-2 md:px-8 md:py-24"
    >
      {
        [mission, vision].map((pillar, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <div class="h-full rounded-2xl border border-line bg-canvas p-8">
              <h3 class="font-display text-2xl font-medium text-secondary">
                {pillar.title}
              </h3>
              <p class="mt-4 leading-relaxed text-muted">
                {pillar.description}
              </p>
            </div>
          </ScrollReveal>
        ))
      }
    </div>
  </section>

  <!-- Values -->
  <section class="mx-auto max-w-7xl px-5 py-20 md:px-8 md:py-28">
    <SectionHeading
      eyebrow="Valores"
      title="Lo que nos define"
      align="center"
    />
    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        valuesAbout.map((v, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <div class="h-full rounded-2xl border border-line bg-panel p-8 text-center">
              <span class="font-display text-4xl font-semibold text-secondary/30">
                0{i + 1}
              </span>
              <h3 class="mt-3 font-display text-xl font-medium text-ink">
                {v.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">
                {v.description}
              </p>
            </div>
          </ScrollReveal>
        ))
      }
    </div>
  </section>

  <CtaBanner
    bgSrc={Images[0].image.src}
    title={aboutCta.title}
    description={aboutCta.description}
    primaryLabel={aboutCta.primaryLabel}
    primaryHref={aboutCta.primaryHref}
    secondaryLabel={aboutCta.secondaryLabel}
    secondaryHref={aboutCta.secondaryHref}
  />
</Layout>
